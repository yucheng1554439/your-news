# Same publishable key as web (.env.local NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Dev machine LAN IP — NOT localhost on a physical phone
# Find yours: ipconfig (Windows) or ifconfig (Mac). Example:
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.199:3000/api/v1

# Production legal page origin (privacy, terms, support) — no trailing slash
# EXPO_PUBLIC_LEGAL_BASE_URL=https://yournews.app
