# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# NewsAPI (server-only) — ingested centrally, not per page
NEWS_API_KEY=
# Story pool cache: fresh TTL (ms), default 1200000 (20 min)
NEWS_CACHE_TTL_MS=1200000
# Max age to serve stale pool when API fails (ms), default 604800000 (7 days)
NEWS_STALE_MAX_MS=604800000

# REQUIRED on Vercel — intelligence snapshots, briefings, story pool (Upstash or Vercel KV)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Or Vercel KV (same client):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Local dev only: file fallback when Redis is not set (disabled automatically on Vercel)
NEWS_FILE_PERSISTENCE=true

# Intelligence — Anthropic (primary when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

AI_PROVIDER=anthropic
# Set to false to throw instead of template fallback when Claude fails
AI_ALLOW_FALLBACK=true

# Optional OpenAI fallback provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
