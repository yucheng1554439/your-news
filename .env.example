# =============================================================================
# Your News — Environment Variables
# Copy to `.env.local` (web) and `mobile/.env` (Expo). Never commit secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Auth (Clerk)
# Web + API session cookies and mobile Bearer JWT verification
# -----------------------------------------------------------------------------
# Publishable key — safe for client bundles (web + EXPO_PUBLIC_* mirror on mobile)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Server-only — API v1 Bearer verification, server actions, middleware
CLERK_SECRET_KEY=
# Optional — custom Clerk domain for production
# NEXT_PUBLIC_CLERK_DOMAIN=

# -----------------------------------------------------------------------------
# Database / Persistence (Redis / Vercel KV)
# Required in production — intelligence snapshots, briefings, story pool, UIP
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV aliases (same client when deployed on Vercel)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Local dev only: JSON file fallback when Redis is unset (auto-disabled on Vercel)
NEWS_FILE_PERSISTENCE=true

# -----------------------------------------------------------------------------
# News ingestion (NewsAPI)
# Centralized server-side ingest — not fetched per page view
# -----------------------------------------------------------------------------
NEWS_API_KEY=
# Story pool fresh TTL (ms), default 1200000 (20 min)
NEWS_CACHE_TTL_MS=1200000
# Max age to serve stale pool when NewsAPI fails (ms), default 604800000 (7 days)
# Note: reserved for future stale-serve policy; currently documented for ops
NEWS_STALE_MAX_MS=604800000

# -----------------------------------------------------------------------------
# AI (Intelligence generation)
# Anthropic primary; OpenAI optional fallback
# -----------------------------------------------------------------------------
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Set false to fail loudly instead of template fallback when AI errors
AI_ALLOW_FALLBACK=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Public site URL (legal pages, App Store Privacy Policy URL)
NEXT_PUBLIC_APP_URL=https://yournews.app
# Set in mobile/.env — must match deployed API origin
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAN_IP:3000/api/v1
# EXPO_PUBLIC_LEGAL_BASE_URL=https://yournews.app
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# EXPO_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# EXPO_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# -----------------------------------------------------------------------------
# Analytics (optional — not wired by default)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
# SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Debug / development (never enable in production)
# -----------------------------------------------------------------------------
# BRIEFING_DEBUG=1
# DEBUG_ISOLATION=1
